PORT=8787
FRONTEND_ORIGIN=http://127.0.0.1:5500
APP_RETURN_URL=http://127.0.0.1:5500/index.html

# Llaves sandbox de Wompi
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxxxx

# Opcional: guardar premium en Firebase RTDB
# Ejemplo: https://tu-proyecto-default-rtdb.firebaseio.com
FIREBASE_DB_URL=

# Credenciales para acceso al panel de drogueria
PANEL_ACCESS_EMAIL=tu_correo_de_drogueria@gmail.com
PANEL_ACCESS_PASSWORD=tu_clave_segura
# Opcional: hash SHA-256 de la clave (si se define, tiene prioridad sobre PANEL_ACCESS_PASSWORD)
PANEL_ACCESS_PASSWORD_HASH=
PANEL_MAX_ATTEMPTS=5
PANEL_LOCK_MINUTES=10

# Dias de vigencia premium por pago (opcional, default 30)
PREMIUM_DURATION_DAYS=30
